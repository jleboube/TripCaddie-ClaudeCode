# TripCaddie IQBE - User Configuration
# Copy to .env and customize, OR just run ./deploy.sh (creates defaults)
#
# NOTE: Cryptographic secrets (DB_PASSWORD, NEXTAUTH_SECRET, ENCRYPTION_KEY)
# are AUTO-GENERATED on first deploy. You don't need to set them.

# ============================================
# REQUIRED - You must set these
# ============================================

# Admin Account (created on first startup)
ADMIN_EMAIL=admin@tripcaddie.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=changeme123

# ============================================
# OPTIONAL - Defaults work for local dev
# ============================================

# Application URL (change for production)
NEXTAUTH_URL=http://localhost:47319

# Email Service (leave empty to disable emails)
# Get your API key at https://resend.com
EMAIL_FROM=noreply@tripcaddie.com
RESEND_API_KEY=

# ============================================
# AUTO-GENERATED - Do not set manually
# These are created in .secrets on first deploy
# ============================================
# DB_PASSWORD      - PostgreSQL password
# NEXTAUTH_SECRET  - Session encryption key
# ENCRYPTION_KEY   - AES-256 key for PII
