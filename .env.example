# TripCaddie IQBE Configuration
# Copy this file to .env and fill in your values
# Or run: npm run setup (interactive setup)

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:47319

# Database
DATABASE_URL=postgresql://tripcaddie:your_db_password@db:5432/tripcaddie
DB_PASSWORD=your_db_password

# Redis
REDIS_URL=redis://redis:6379

# Authentication (NextAuth.js)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:47319

# Admin Account (created on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=your_secure_admin_password

# Email (Resend)
# Get your API key at https://resend.com
EMAIL_FROM=noreply@tripcaddie.com
RESEND_API_KEY=re_your_api_key_here

# Encryption (AES-256 key for PII)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your_32_byte_base64_key_here
